'use client';

import { useState, useEffect } from 'react';
import { createClient } from '@/lib/supabase/client';
import { useWorkspace } from '@/contexts/WorkspaceContext';
import { useT, useI18n } from '@/components/i18n/I18nContext';
import { useRouter } from 'next/navigation';
import Button from '@/components/ui/Button';
import Input from '@/components/ui/Input';
import { cn } from '@/lib/utils';
import type { KnowledgeBaseEntry, KBCategory, KB_CATEGORIES } from '@/types/database';

const CATEGORIES: { value: string; label: string; icon: string }[] = [
  { value: 'parking', label: 'Parking', icon: '🅿️' },
  { value: 'wifi', label: 'WiFi', icon: '📶' },
  { value: 'horaris', label: 'Horaris', icon: '🕐' },
  { value: 'política', label: 'Política', icon: '📋' },
  { value: 'menú', label: 'Menú / Cuina', icon: '🍽️' },
  { value: 'equip', label: 'Equip', icon: '👥' },
  { value: 'instal·lacions', label: 'Instal·lacions', icon: '🏢' },
  { value: 'ubicació', label: 'Ubicació', icon: '📍' },
  { value: 'promoció', label: 'Promocions', icon: '🎁' },
  { value: 'altres', label: 'Altres', icon: '📝' },
];

export default function SettingsPage() {
  const { biz, org, reload } = useWorkspace();
  const t = useT();
  const [tab, setTab] = useState<'voice' | 'kb' | 'billing' | 'integrations' | 'growth' | 'safety' | 'triggers' | 'team' | 'lang'>('voice');

  if (!biz) return <div className="p-8 text-center text-surface-400">{t('common.loading')}</div>;

  const TABS: [string, string][] = [
    ['voice', t('settings.tabs.voice')],
    ['kb', t('settings.tabs.kb')],
    ['billing', t('settings.tabs.billing')],
    ['integrations', t('settings.tabs.integrations')],
    ['growth', t('settings.tabs.growth')],
    ['safety', t('settings.tabs.safety')],
    ['triggers', '⚡ Triggers'],
    ['team', '👥 Team'],
    ['lang', t('settings.tabs.language')],
  ];

  return (
    <div className="p-6">
      <h1 className="font-display font-bold text-lg mb-6">{t('settings.title')} — {biz.name}</h1>

      <div className="flex gap-2 mb-6 flex-wrap">
        {TABS.map(([k, l]) => (
          <button key={k} onClick={() => setTab(k as any)}
            className={cn('px-4 py-2 rounded-xl text-sm font-medium border transition-all',
              tab === k ? 'border-brand-400 bg-brand-50 text-brand-700' : 'border-surface-200 hover:border-surface-300 text-surface-600')}>
            {l}
          </button>
        ))}
      </div>

      {tab === 'voice' && <VoiceSettings biz={biz} onSaved={reload} />}
      {tab === 'kb' && <BusinessMemorySettings biz={biz} org={org!} />}
      {tab === 'billing' && <BillingSettings org={org!} />}
      {tab === 'integrations' && <IntegrationsPlaceholder />}
      {tab === 'growth' && <GrowthSettings biz={biz} org={org!} />}
      {tab === 'safety' && <SafetySettings biz={biz} org={org!} onSaved={reload} />}
      {tab === 'triggers' && <ActionTriggersSettings biz={biz} org={org!} />}
      {tab === 'team' && <TeamSettings org={org!} />}
      {tab === 'lang' && <LanguageSettings />}
    </div>
  );
}

// ============================================================
// VOICE SETTINGS (unchanged)
// ============================================================
function VoiceSettings({ biz, onSaved }: { biz: any; onSaved: () => void }) {
  const t = useT();
  const [signature, setSignature] = useState(biz.default_signature);
  const [instructions, setInstructions] = useState(biz.ai_instructions || '');
  const [posKeywords, setPosKeywords] = useState((biz.tone_keywords_positive || []).join(', '));
  const [negKeywords, setNegKeywords] = useState((biz.tone_keywords_negative || []).join(', '));
  // SEO — use new fields with fallback to old
  const seoRules = biz.seo_rules || { max_keywords_per_reply: 2, avoid_if_negative: true, min_rating_for_keywords: 4 };
  const [seoMode, setSeoMode] = useState(biz.seo_enabled ?? biz.seo_mode ?? false);
  const [seoMaxKw, setSeoMaxKw] = useState(seoRules.max_keywords_per_reply ?? biz.seo_aggressiveness ?? 2);
  const [seoAvoidNeg, setSeoAvoidNeg] = useState(seoRules.avoid_if_negative ?? true);
  const [seoMinRating, setSeoMinRating] = useState(seoRules.min_rating_for_keywords ?? 4);
  const [seoKeywords, setSeoKeywords] = useState(
    [...new Set([...(biz.seo_keywords || []), ...(biz.target_keywords || [])])].join(', ')
  );
  const [saving, setSaving] = useState(false);
  const [saved, setSaved] = useState(false);
  const supabase = createClient();

  const handleSave = async () => {
    setSaving(true);
    const kwArr = seoKeywords.split(',').map(s => s.trim()).filter(Boolean);
    await supabase.from('businesses').update({
      default_signature: signature,
      ai_instructions: instructions || null,
      tone_keywords_positive: posKeywords.split(',').map(s => s.trim()).filter(Boolean),
      tone_keywords_negative: negKeywords.split(',').map(s => s.trim()).filter(Boolean),
      // Write both old + new SEO fields for backward compat
      seo_mode: seoMode,
      seo_enabled: seoMode,
      seo_aggressiveness: seoMaxKw,
      target_keywords: kwArr,
      seo_keywords: kwArr,
      seo_rules: {
        max_keywords_per_reply: seoMaxKw,
        avoid_if_negative: seoAvoidNeg,
        min_rating_for_keywords: seoMinRating,
      },
    }).eq('id', biz.id);
    await onSaved();
    setSaving(false);
    setSaved(true);
    setTimeout(() => setSaved(false), 2000);
  };

  // SEO level labels from messages (array)
  const seoLevels: string[] = (() => {
    try {
      const raw = t('settings.voice.seoLevels');
      return typeof raw === 'string' ? ['—', raw] : ['—', 'Suau', 'Mitjà', 'Alt'];
    } catch { return ['—', 'Suau', 'Mitjà', 'Alt']; }
  })();

  return (
    <div className="bg-white rounded-2xl border border-surface-100 p-6 space-y-5 max-w-2xl">
      <Input label={t('settings.voice.signature')} value={signature} onChange={e => setSignature(e.target.value)} />
      <div>
        <label className="block text-sm font-medium text-surface-700 mb-1">{t('settings.voice.instructions')}</label>
        <textarea value={instructions} onChange={e => setInstructions(e.target.value)}
          placeholder={t('settings.voice.instructionsPlaceholder')}
          className="w-full min-h-[100px] rounded-xl border border-surface-200 px-4 py-3 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 transition-all" />
      </div>
      <Input label={t('settings.voice.posKeywords')} value={posKeywords} onChange={e => setPosKeywords(e.target.value)} placeholder={t('settings.voice.posPlaceholder')} />
      <Input label={t('settings.voice.negKeywords')} value={negKeywords} onChange={e => setNegKeywords(e.target.value)} placeholder={t('settings.voice.negPlaceholder')} />

      {/* AI Engine — provider abstracted */}
      <div className="flex items-center gap-3 py-3 px-4 rounded-xl bg-surface-50 border border-surface-100">
        <span className="text-lg">🤖</span>
        <div>
          <p className="text-sm font-medium text-surface-800">OpinIA AI</p>
          <p className="text-xs text-surface-400">{t('settings.voice.aiEngineDesc')}</p>
        </div>
      </div>

      {/* SEO & Visibility */}
      <div className="border-t border-surface-100 pt-5 space-y-4">
        <div className="flex items-center justify-between">
          <div>
            <h3 className="text-sm font-semibold text-surface-800">🔍 {t('settings.voice.seo')}</h3>
            <p className="text-xs text-surface-400 mt-0.5">{t('settings.voice.seoDesc')}</p>
          </div>
          <button onClick={() => setSeoMode(!seoMode)}
            className={cn('relative w-12 h-6 rounded-full transition-colors', seoMode ? 'bg-brand-500' : 'bg-surface-300')}>
            <span className={cn('absolute top-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform', seoMode ? 'translate-x-6' : 'translate-x-0.5')} />
          </button>
        </div>

        {seoMode && (
          <>
            <Input
              label={t('settings.voice.seoKeywords')}
              value={seoKeywords}
              onChange={e => setSeoKeywords(e.target.value)}
              placeholder={t('settings.voice.seoKeywordsPlaceholder')}
            />
            <div>
              <label className="block text-sm font-medium text-surface-700 mb-2">
                {t('settings.voice.seoIntensity')}: {seoLevels[seoMaxKw] || seoMaxKw}
                <span className="text-xs text-surface-400 ml-2">
                  ({t('settings.voice.seoMaxKw', { n: seoMaxKw })})
                </span>
              </label>
              <input
                type="range" min={1} max={3} value={seoMaxKw}
                onChange={e => setSeoMaxKw(Number(e.target.value))}
                className="w-full h-2 bg-surface-200 rounded-lg appearance-none cursor-pointer accent-brand-500"
              />
              <div className="flex justify-between text-[10px] text-surface-400 mt-1">
                <span>{seoLevels[1]}</span><span>{seoLevels[2]}</span><span>{seoLevels[3]}</span>
              </div>
            </div>

            {/* Advanced SEO rules */}
            <div className="border-t border-surface-50 pt-3 space-y-3">
              <p className="text-[10px] uppercase font-bold text-surface-400 tracking-wider">Advanced</p>
              <label className="flex items-center gap-2 text-sm text-surface-700 cursor-pointer">
                <input type="checkbox" checked={seoAvoidNeg} onChange={e => setSeoAvoidNeg(e.target.checked)}
                  className="rounded border-surface-300 text-brand-600 focus:ring-brand-500" />
                Skip SEO keywords on negative reviews
              </label>
              <div className="flex items-center gap-3">
                <label className="text-sm text-surface-700">Min rating for keywords:</label>
                <select value={seoMinRating} onChange={e => setSeoMinRating(Number(e.target.value))}
                  className="rounded-lg border border-surface-200 px-3 py-1.5 text-sm">
                  <option value={1}>1+</option>
                  <option value={2}>2+</option>
                  <option value={3}>3+</option>
                  <option value={4}>4+</option>
                  <option value={5}>5 only</option>
                </select>
              </div>
            </div>
          </>
        )}
      </div>

      <div className="flex items-center gap-3">
        <Button onClick={handleSave} loading={saving}>{t('settings.voice.saveChanges')}</Button>
        {saved && <span className="text-sm text-emerald-600 font-medium animate-fade-in">✅ {t('common.saved')}</span>}
      </div>
    </div>
  );
}

// ============================================================
// BUSINESS MEMORY — Premium CRUD with categories + triggers
// ============================================================
function BusinessMemorySettings({ biz, org }: { biz: any; org: any }) {
  const [entries, setEntries] = useState<KnowledgeBaseEntry[]>([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [editId, setEditId] = useState<string | null>(null);
  const [category, setCategory] = useState('altres');
  const [content, setContent] = useState('');
  const [triggers, setTriggers] = useState('');
  const [sentimentCtx, setSentimentCtx] = useState('');
  const [saving, setSaving] = useState(false);
  const [filterCat, setFilterCat] = useState<string | null>(null);
  const supabase = createClient();

  const loadEntries = async () => {
    const { data } = await supabase
      .from('knowledge_base_entries')
      .select('*')
      .eq('biz_id', biz.id)
      .order('category')
      .order('created_at', { ascending: false });
    setEntries((data as KnowledgeBaseEntry[]) || []);
    setLoading(false);
  };

  useEffect(() => { loadEntries(); }, [biz.id]);

  const handleSave = async () => {
    if (!content.trim()) return;
    setSaving(true);

    const triggersArray = triggers
      .split(',')
      .map(t => t.trim().toLowerCase())
      .filter(Boolean);

    const payload = {
      category,
      content,
      triggers: triggersArray,
      sentiment_context: sentimentCtx || null,
    };

    if (editId) {
      await supabase.from('knowledge_base_entries').update(payload).eq('id', editId);
    } else {
      await supabase.from('knowledge_base_entries').insert({
        ...payload,
        biz_id: biz.id,
        org_id: org.id,
      });
    }

    resetForm();
    setSaving(false);
    loadEntries();
  };

  const handleEdit = (e: KnowledgeBaseEntry) => {
    setEditId(e.id);
    setCategory(e.category);
    setContent(e.content);
    setTriggers((e.triggers || []).join(', '));
    setSentimentCtx(e.sentiment_context || '');
    setShowForm(true);
  };

  const handleDelete = async (id: string) => {
    if (!confirm('Eliminar aquesta entrada?')) return;
    await supabase.from('knowledge_base_entries').delete().eq('id', id);
    loadEntries();
  };

  const resetForm = () => {
    setShowForm(false);
    setEditId(null);
    setCategory('altres');
    setContent('');
    setTriggers('');
    setSentimentCtx('');
  };

  const filtered = filterCat ? entries.filter(e => e.category === filterCat) : entries;

  // Group by category for display
  const grouped = filtered.reduce((acc, e) => {
    const cat = e.category || 'altres';
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(e);
    return acc;
  }, {} as Record<string, KnowledgeBaseEntry[]>);

  const getCatInfo = (cat: string) => CATEGORIES.find(c => c.value === cat) || { icon: '📝', label: cat };

  return (
    <div className="max-w-3xl space-y-4">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <p className="text-sm text-surface-500">Fets verificats que la IA pot referenciar. Mai inventa més enllà d'això.</p>
          <p className="text-xs text-surface-400 mt-0.5">{entries.length} entrad{entries.length === 1 ? 'a' : 'es'}</p>
        </div>
        <Button size="sm" onClick={() => { resetForm(); setShowForm(true); }}>+ Afegir</Button>
      </div>

      {/* Category filter */}
      <div className="flex gap-1.5 flex-wrap">
        <button onClick={() => setFilterCat(null)}
          className={cn('px-3 py-1 rounded-lg text-xs font-medium border transition-all',
            !filterCat ? 'border-brand-400 bg-brand-50 text-brand-700' : 'border-surface-200 text-surface-500 hover:border-surface-300')}>
          Totes
        </button>
        {CATEGORIES.map(c => {
          const count = entries.filter(e => e.category === c.value).length;
          if (count === 0) return null;
          return (
            <button key={c.value} onClick={() => setFilterCat(filterCat === c.value ? null : c.value)}
              className={cn('px-3 py-1 rounded-lg text-xs font-medium border transition-all',
                filterCat === c.value ? 'border-brand-400 bg-brand-50 text-brand-700' : 'border-surface-200 text-surface-500 hover:border-surface-300')}>
              {c.icon} {c.label} ({count})
            </button>
          );
        })}
      </div>

      {/* Form */}
      {showForm && (
        <div className="bg-white rounded-2xl border-2 border-brand-200 p-5 space-y-4 animate-fade-in shadow-sm">
          <p className="text-sm font-semibold text-surface-800">{editId ? 'Editar entrada' : 'Nova entrada de memòria'}</p>

          {/* Category selector */}
          <div>
            <label className="block text-xs font-medium text-surface-600 mb-2">Categoria</label>
            <div className="grid grid-cols-5 gap-1.5">
              {CATEGORIES.map(c => (
                <button key={c.value} onClick={() => setCategory(c.value)}
                  className={cn('flex flex-col items-center gap-1 p-2 rounded-xl border text-xs transition-all',
                    category === c.value ? 'border-brand-400 bg-brand-50 text-brand-700 shadow-sm' : 'border-surface-200 text-surface-500 hover:border-surface-300')}>
                  <span className="text-lg">{c.icon}</span>
                  <span className="font-medium truncate w-full text-center">{c.label}</span>
                </button>
              ))}
            </div>
          </div>

          {/* Content */}
          <div>
            <label className="block text-xs font-medium text-surface-600 mb-1">Contingut (el que la IA podrà dir)</label>
            <textarea value={content} onChange={e => setContent(e.target.value)}
              placeholder="Ex: Parking gratuït per a clients. Entrada per Av. Catalunya, barrera automàtica."
              className="w-full min-h-[80px] rounded-xl border border-surface-200 px-4 py-3 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 transition-all" />
          </div>

          {/* Triggers */}
          <div>
            <label className="block text-xs font-medium text-surface-600 mb-1">
              Paraules activadores <span className="text-surface-400 font-normal">(separades per coma — quan apareixen a la ressenya, s'activa aquesta entrada)</span>
            </label>
            <input value={triggers} onChange={e => setTriggers(e.target.value)}
              placeholder="parking, aparcar, cotxe, aparcament"
              className="w-full rounded-xl border border-surface-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 transition-all" />
          </div>

          {/* Sentiment context */}
          <div>
            <label className="block text-xs font-medium text-surface-600 mb-1">
              Context per ressenyes negatives <span className="text-surface-400 font-normal">(opcional — com reaccionar si en parlen malament)</span>
            </label>
            <input value={sentimentCtx} onChange={e => setSentimentCtx(e.target.value)}
              placeholder="Ex: Disculpar-se i oferir alternatives de parking proper"
              className="w-full rounded-xl border border-surface-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 transition-all" />
          </div>

          <div className="flex gap-2 pt-1">
            <Button onClick={handleSave} loading={saving}>{editId ? 'Actualitzar' : 'Desar entrada'}</Button>
            <Button variant="ghost" onClick={resetForm}>Cancel·lar</Button>
          </div>
        </div>
      )}

      {/* Entries list */}
      {loading ? (
        <div className="space-y-2">{[0,1,2].map(i => <div key={i} className="h-20 bg-surface-100 rounded-xl animate-pulse" />)}</div>
      ) : entries.length === 0 ? (
        <div className="bg-white rounded-2xl border border-surface-100 p-8 text-center">
          <p className="text-3xl mb-3">🧠</p>
          <p className="font-medium text-surface-700 mb-1">Business Memory buit</p>
          <p className="text-sm text-surface-400 mb-4 max-w-md mx-auto">
            Afegeix fets verificats (parking, horaris, WiFi, polítiques) perquè la IA doni respostes precises i mai inventi informació.
          </p>
          <div className="flex flex-wrap gap-2 justify-center mb-5">
            {['🅿️ parking, aparcar', '📶 wifi, internet', '🕐 horari, check-in', '📋 cancel·lació, mascotes', '🍽️ menú, carta'].map(ex => (
              <span key={ex} className="px-2.5 py-1 bg-surface-50 rounded-lg text-xs text-surface-500 border border-surface-100">{ex}</span>
            ))}
          </div>
          <Button size="sm" onClick={() => setShowForm(true)}>+ Crear primera entrada</Button>
        </div>
      ) : (
        <div className="space-y-6">
          {Object.entries(grouped).map(([cat, items]) => {
            const catInfo = getCatInfo(cat);
            return (
              <div key={cat}>
                <div className="flex items-center gap-2 mb-2">
                  <span className="text-sm">{catInfo.icon}</span>
                  <span className="text-xs font-bold uppercase text-surface-500 tracking-wider">{catInfo.label}</span>
                  <span className="text-[10px] text-surface-400">({items.length})</span>
                </div>
                <div className="space-y-2">
                  {items.map(e => (
                    <div key={e.id} className="bg-white rounded-xl border border-surface-100 p-4 group hover:border-surface-200 hover:shadow-sm transition-all">
                      <div className="flex items-start gap-3">
                        <div className="flex-1 min-w-0">
                          <p className="text-sm text-surface-800 leading-relaxed">{e.content}</p>

                          {e.triggers.length > 0 && (
                            <div className="flex gap-1 flex-wrap mt-2">
                              {e.triggers.map((t, i) => (
                                <span key={i} className="text-[10px] px-2 py-0.5 rounded-full bg-violet-50 text-violet-600 border border-violet-100 font-medium">
                                  {t}
                                </span>
                              ))}
                            </div>
                          )}

                          {e.sentiment_context && (
                            <p className="text-xs text-amber-600 mt-1.5 flex items-center gap-1">
                              <span>⚡</span> {e.sentiment_context}
                            </p>
                          )}
                        </div>

                        <div className="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
                          <button onClick={() => handleEdit(e)} className="p-1.5 rounded-lg hover:bg-surface-100 text-surface-400 hover:text-surface-600">
                            <svg className="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}><path strokeLinecap="round" strokeLinejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                          </button>
                          <button onClick={() => handleDelete(e.id)} className="p-1.5 rounded-lg hover:bg-red-50 text-surface-400 hover:text-red-500">
                            <svg className="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}><path strokeLinecap="round" strokeLinejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                          </button>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

// ============================================================
// BILLING & USAGE
// ============================================================
function BillingSettings({ org }: { org: any }) {
  const [data, setData] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [upgrading, setUpgrading] = useState<string | null>(null);

  useEffect(() => {
    loadBilling();
  }, [org.id]);

  const loadBilling = async () => {
    setLoading(true);
    try {
      const res = await fetch(`/api/billing?org_id=${org.id}`);
      const json = await res.json();
      setData(json);
    } catch (e) { console.error(e); }
    setLoading(false);
  };

  const handleUpgrade = async (planId: string) => {
    setUpgrading(planId);
    try {
      const res = await fetch('/api/billing', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ org_id: org.id, plan_id: planId }),
      });
      const json = await res.json();
      if (json.success) {
        await loadBilling();
      } else if (json.action === 'stripe_checkout') {
        alert(json.message);
      }
    } catch (e) { console.error(e); }
    setUpgrading(null);
  };

  if (loading) {
    return <div className="space-y-4 max-w-3xl">{[0,1,2].map(i => <div key={i} className="h-24 bg-surface-100 rounded-xl animate-pulse" />)}</div>;
  }

  if (!data) return <div className="text-surface-400">Error carregant dades de facturació</div>;

  const usagePct = data.limits.max_reviews_mo > 0
    ? Math.round((data.usage.ai_generations / data.limits.max_reviews_mo) * 100)
    : 0;

  return (
    <div className="max-w-3xl space-y-6">
      {/* Current usage */}
      <div className="bg-white rounded-2xl border border-surface-100 p-6">
        <h3 className="font-semibold text-surface-900 mb-4">Ús del mes actual</h3>
        <div className="grid grid-cols-3 gap-4 mb-4">
          <div className="text-center p-3 rounded-xl bg-surface-50">
            <p className="text-2xl font-bold text-surface-900">{data.usage.ai_generations}</p>
            <p className="text-xs text-surface-500">Generacions IA</p>
          </div>
          <div className="text-center p-3 rounded-xl bg-surface-50">
            <p className="text-2xl font-bold text-surface-900">{data.usage.reviews_synced || 0}</p>
            <p className="text-xs text-surface-500">Ressenyes sync</p>
          </div>
          <div className="text-center p-3 rounded-xl bg-surface-50">
            <p className="text-2xl font-bold text-surface-900">{data.limits.max_reviews_mo}</p>
            <p className="text-xs text-surface-500">Límit mensual</p>
          </div>
        </div>

        {/* Progress bar */}
        <div className="mb-1">
          <div className="flex justify-between text-xs text-surface-500 mb-1">
            <span>{data.usage.ai_generations} / {data.limits.max_reviews_mo} generacions</span>
            <span>{usagePct}%</span>
          </div>
          <div className="w-full h-2.5 bg-surface-100 rounded-full overflow-hidden">
            <div className={cn('h-full rounded-full transition-all duration-500',
              usagePct >= 90 ? 'bg-red-500' : usagePct >= 70 ? 'bg-amber-500' : 'bg-brand-500')}
              style={{ width: `${Math.min(usagePct, 100)}%` }} />
          </div>
        </div>
      </div>

      {/* Plan cards */}
      <div>
        <h3 className="font-semibold text-surface-900 mb-4">Plans disponibles</h3>
        <div className="grid md:grid-cols-3 gap-4">
          {(data.plans || []).map((plan: any) => {
            const isCurrent = data.org.plan === plan.id;
            return (
              <div key={plan.id} className={cn(
                'rounded-2xl border-2 p-5 transition-all',
                isCurrent ? 'border-brand-400 bg-brand-50/30 shadow-sm' : 'border-surface-200 hover:border-surface-300'
              )}>
                <div className="flex items-center justify-between mb-2">
                  <h4 className="font-bold text-surface-900">{plan.name}</h4>
                  {isCurrent && <span className="text-[10px] px-2 py-0.5 rounded-full bg-brand-100 text-brand-700 font-bold">ACTUAL</span>}
                </div>
                <p className="text-2xl font-bold text-surface-900 mb-3">
                  {plan.price_monthly === 0 ? 'Gratis' : `${plan.price_monthly}€`}
                  {plan.price_monthly > 0 && <span className="text-sm font-normal text-surface-400">/mes</span>}
                </p>
                <ul className="space-y-1.5 mb-4">
                  {plan.features.map((f: string, i: number) => (
                    <li key={i} className="text-xs text-surface-600 flex items-center gap-1.5">
                      <span className="text-brand-500">✓</span> {f}
                    </li>
                  ))}
                </ul>
                {!isCurrent && (
                  <Button size="sm" variant={plan.price_monthly > 0 ? 'primary' : 'secondary'}
                    onClick={() => handleUpgrade(plan.id)}
                    loading={upgrading === plan.id}
                    className="w-full">
                    {plan.price_monthly === 0 ? 'Canviar a Free' : `Upgrade a ${plan.name}`}
                  </Button>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}

// ============================================================
// INTEGRATIONS (unchanged)
// ============================================================
function IntegrationsPlaceholder() {
  return (
    <div className="max-w-2xl space-y-4">
      <div className="bg-white rounded-xl border border-surface-100 p-6">
        <div className="flex items-center gap-3 mb-3">
          <span className="text-2xl">🔵</span>
          <div>
            <p className="font-medium text-surface-900">Google Business Profile</p>
            <p className="text-xs text-surface-400">Sync automàtic de ressenyes + publicació de respostes</p>
          </div>
        </div>
        <Button variant="secondary" disabled>Pròximament</Button>
      </div>
      <div className="bg-white rounded-xl border border-surface-100 p-6 opacity-60">
        <div className="flex items-center gap-3 mb-3">
          <span className="text-2xl">🟢</span>
          <div>
            <p className="font-medium text-surface-900">TripAdvisor</p>
            <p className="text-xs text-surface-400">Importació per URL o CSV</p>
          </div>
        </div>
        <span className="text-xs text-surface-400">Estructura preparada</span>
      </div>
    </div>
  );
}

// ============================================================
// GROWTH SETTINGS (QR + Short Links + Tracking)
// ============================================================
function GrowthSettings({ biz, org }: { biz: any; org: any }) {
  const supabase = createClient();
  const [links, setLinks] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [creating, setCreating] = useState(false);
  const [targetUrl, setTargetUrl] = useState('');
  const [copiedId, setCopiedId] = useState<string | null>(null);

  const loadLinks = async () => {
    setLoading(true);
    const res = await fetch(`/api/growth-links?biz_id=${biz.id}`);
    if (res.ok) setLinks(await res.json());
    setLoading(false);
  };

  useEffect(() => { loadLinks(); }, [biz.id]);

  const handleCreate = async () => {
    if (!targetUrl.trim()) return;
    setCreating(true);
    const res = await fetch('/api/growth-links', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ biz_id: biz.id, org_id: org.id, target_url: targetUrl }),
    });
    if (res.ok) {
      setTargetUrl('');
      await loadLinks();
    }
    setCreating(false);
  };

  const handleDelete = async (id: string) => {
    if (!confirm('Eliminar aquest enllaç?')) return;
    await fetch(`/api/growth-links?id=${id}`, { method: 'DELETE' });
    setLinks(links.filter(l => l.id !== id));
  };

  const copyLink = (slug: string, id: string) => {
    const url = `${window.location.origin}/api/g/${slug}`;
    navigator.clipboard.writeText(url);
    setCopiedId(id);
    setTimeout(() => setCopiedId(null), 2000);
  };

  const totalClicks7d = links.reduce((s, l) => s + (l.clicks_7d || 0), 0);

  return (
    <div className="space-y-6">
      {/* Stats */}
      <div className="grid grid-cols-3 gap-4">
        <div className="glass-card rounded-xl p-4 border border-surface-200/50 text-center">
          <p className="text-2xl font-bold text-surface-900">{links.length}</p>
          <p className="text-xs text-surface-500">Enllaços actius</p>
        </div>
        <div className="glass-card rounded-xl p-4 border border-surface-200/50 text-center">
          <p className="text-2xl font-bold text-brand-600">{totalClicks7d}</p>
          <p className="text-xs text-surface-500">Clics (7 dies)</p>
        </div>
        <div className="glass-card rounded-xl p-4 border border-surface-200/50 text-center">
          <p className="text-2xl font-bold text-green-600">{links.reduce((s, l) => s + (l.scan_count || 0), 0)}</p>
          <p className="text-xs text-surface-500">Total escanejos</p>
        </div>
      </div>

      {/* Create new */}
      <div className="glass-card rounded-xl p-5 border border-surface-200/50">
        <h3 className="font-semibold text-surface-800 mb-3">📎 Crear nou enllaç de ressenya</h3>
        <p className="text-xs text-surface-500 mb-3">
          Enganxa el teu Google review link per generar un QR i enllaç curt amb tracking.
        </p>
        <div className="flex gap-2">
          <Input
            value={targetUrl}
            onChange={e => setTargetUrl(e.target.value)}
            placeholder="https://g.page/r/xxx/review o qualsevol URL"
            className="flex-1"
          />
          <Button onClick={handleCreate} loading={creating} disabled={!targetUrl.trim()}>
            + Crear
          </Button>
        </div>
      </div>

      {/* Links list */}
      {loading ? (
        <div className="text-center py-8 text-surface-400">Carregant...</div>
      ) : links.length === 0 ? (
        <div className="text-center py-12">
          <p className="text-4xl mb-3">🔗</p>
          <p className="font-semibold text-surface-700 mb-1">Cap enllaç creat</p>
          <p className="text-sm text-surface-500">Crea el teu primer growth link per començar a recollir ressenyes.</p>
        </div>
      ) : (
        <div className="space-y-3">
          {links.map(link => (
            <div key={link.id} className="glass-card rounded-xl p-4 border border-surface-200/50 flex items-center gap-4">
              {/* QR placeholder */}
              <div className="w-16 h-16 bg-surface-100 rounded-lg flex items-center justify-center text-2xl flex-shrink-0 border border-surface-200">
                📱
              </div>

              <div className="flex-1 min-w-0">
                <p className="text-sm font-medium text-surface-800 truncate">{link.target_url}</p>
                <p className="text-xs text-brand-600 font-mono mt-0.5">{window.location.origin}/api/g/{link.slug}</p>
                <div className="flex items-center gap-3 mt-1">
                  <span className="text-xs text-surface-500">📊 {link.clicks_7d || 0} clics (7d)</span>
                  <span className="text-xs text-surface-500">📱 {link.scan_count || 0} total</span>
                </div>
              </div>

              <div className="flex items-center gap-2 flex-shrink-0">
                <Button variant="ghost" size="sm" onClick={() => copyLink(link.slug, link.id)}>
                  {copiedId === link.id ? '✅ Copiat' : '📋 Copiar'}
                </Button>
                <Button variant="ghost" size="sm" onClick={() => handleDelete(link.id)} className="text-red-500 hover:text-red-700">
                  🗑️
                </Button>
              </div>
            </div>
          ))}
        </div>
      )}

      {/* QR generation note */}
      <div className="bg-surface-50 rounded-xl p-4 border border-surface-100">
        <p className="text-xs text-surface-500">
          💡 <strong>Consell:</strong> Genera un QR amb qualsevol eina (qr-code-generator.com) apuntant a l&apos;enllaç curt.
          OpinIA comptarà cada clic i escaneig automàticament. Ideal per targetes, taula del restaurant, o recepció.
        </p>
      </div>
    </div>
  );
}

// ============================================================
// SAFETY SETTINGS (Panic Button + Negative Constraints)
// ============================================================
function SafetySettings({ biz, org, onSaved }: { biz: any; org: any; onSaved: () => void }) {
  const t = useT();
  const supabase = createClient();
  const [panicMode, setPanicMode] = useState(biz.panic_mode || false);
  const [panicReason, setPanicReason] = useState(biz.panic_reason || '');
  const [toggling, setToggling] = useState(false);

  const [constraints, setConstraints] = useState<string>(
    Array.isArray(biz.negative_constraints) ? biz.negative_constraints.join('\n') : ''
  );
  const [savingConstraints, setSavingConstraints] = useState(false);
  const [savedConstraints, setSavedConstraints] = useState(false);

  const handleTogglePanic = async () => {
    setToggling(true);
    const newMode = !panicMode;
    await supabase.from('businesses').update({
      panic_mode: newMode,
      panic_reason: newMode ? (panicReason || null) : null,
      panic_enabled_at: newMode ? new Date().toISOString() : null,
    }).eq('id', biz.id);

    // Audit via API (activity_log may not have client insert RLS)
    await fetch('/api/audit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: newMode ? 'panic_mode_enabled' : 'panic_mode_disabled',
        org_id: org.id,
        biz_id: biz.id,
        metadata: { reason: panicReason || null },
      }),
    }).catch(() => {});

    setPanicMode(newMode);
    await onSaved();
    setToggling(false);
  };

  const handleSaveConstraints = async () => {
    setSavingConstraints(true);
    const arr = constraints.split('\n').map(s => s.trim()).filter(Boolean);
    await supabase.from('businesses').update({
      negative_constraints: arr,
    }).eq('id', biz.id);
    await onSaved();
    setSavingConstraints(false);
    setSavedConstraints(true);
    setTimeout(() => setSavedConstraints(false), 2000);
  };

  return (
    <div className="space-y-6 max-w-2xl">
      {/* Panic Button */}
      <div className={cn(
        'rounded-2xl border p-6',
        panicMode ? 'border-red-300 bg-red-50/50' : 'border-surface-200 bg-white'
      )}>
        <div className="flex items-center justify-between mb-4">
          <div>
            <h3 className="font-semibold text-surface-800 flex items-center gap-2">
              🚨 {t('settings.safety.panicTitle')}
            </h3>
            <p className="text-xs text-surface-500 mt-1">{t('settings.safety.panicDesc')}</p>
          </div>
          <button
            onClick={handleTogglePanic}
            disabled={toggling}
            className={cn(
              'relative w-14 h-7 rounded-full transition-colors',
              panicMode ? 'bg-red-500' : 'bg-surface-300',
              toggling && 'opacity-50'
            )}
          >
            <span className={cn(
              'absolute top-0.5 w-6 h-6 rounded-full bg-white shadow transition-transform',
              panicMode ? 'translate-x-7' : 'translate-x-0.5'
            )} />
          </button>
        </div>

        {panicMode && (
          <div className="space-y-3">
            <div className="flex items-center gap-2 text-sm text-red-700 font-medium">
              <span className="w-2 h-2 rounded-full bg-red-500 animate-pulse" />
              {t('settings.safety.panicActive', { date: biz.panic_enabled_at ? new Date(biz.panic_enabled_at).toLocaleString('ca') : '—' })}
            </div>
            <div>
              <label className="text-xs text-surface-600 block mb-1">{t('settings.safety.panicReason')}</label>
              <Input value={panicReason} onChange={e => setPanicReason(e.target.value)}
                placeholder={t('settings.safety.panicReasonPlaceholder')} />
            </div>
          </div>
        )}
      </div>

      {/* Negative Constraints */}
      <div className="rounded-2xl border border-surface-200 bg-white p-6">
        <h3 className="font-semibold text-surface-800 mb-1">🚫 {t('settings.safety.constraints')}</h3>
        <p className="text-xs text-surface-500 mb-4">{t('settings.safety.constraintsDesc')}</p>

        <textarea
          value={constraints}
          onChange={e => setConstraints(e.target.value)}
          rows={5}
          placeholder={t('settings.safety.constraintsPlaceholder')}
          className="w-full rounded-xl border border-surface-200 px-4 py-3 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 transition-all"
        />

        <div className="flex items-center gap-3 mt-4">
          <Button onClick={handleSaveConstraints} loading={savingConstraints}>{t('settings.safety.saveConstraints')}</Button>
          {savedConstraints && <span className="text-sm text-emerald-600 font-medium">✅ {t('common.saved')}</span>}
        </div>
      </div>

      {/* Info */}
      <div className="bg-surface-50 rounded-xl p-4 border border-surface-100">
        <p className="text-xs text-surface-500">💡 {t('settings.safety.defaultsInfo')}</p>
      </div>
    </div>
  );
}

// ============================================================
// LANGUAGE SETTINGS
// ============================================================
const LOCALE_OPTS = [
  { id: 'ca', flag: '🇦🇩', label: 'Català' },
  { id: 'es', flag: '🇪🇸', label: 'Español' },
  { id: 'en', flag: '🇬🇧', label: 'English' },
];

function LanguageSettings() {
  const t = useT();
  const { locale } = useI18n();
  const router = useRouter();
  const [saving, setSaving] = useState(false);

  const handleChange = async (newLocale: string) => {
    if (newLocale === locale || saving) return;
    setSaving(true);
    await fetch('/api/locale', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ locale: newLocale }),
    });
    router.refresh();
    setTimeout(() => setSaving(false), 400);
  };

  return (
    <div className="bg-white rounded-2xl border border-surface-100 p-6 max-w-md space-y-4">
      <div>
        <h3 className="font-semibold text-surface-800">🌐 {t('settings.language.title')}</h3>
        <p className="text-xs text-surface-500 mt-1">{t('settings.language.desc')}</p>
      </div>
      <div className="flex gap-2">
        {LOCALE_OPTS.map(l => (
          <button
            key={l.id}
            onClick={() => handleChange(l.id)}
            disabled={saving}
            className={cn(
              'flex-1 px-4 py-3 rounded-xl border text-sm font-medium transition-all flex items-center justify-center gap-2',
              l.id === locale
                ? 'border-brand-400 bg-brand-50 text-brand-700 ring-2 ring-brand-200'
                : 'border-surface-200 hover:border-surface-300 text-surface-600',
              saving && 'opacity-50'
            )}
          >
            <span className="text-lg">{l.flag}</span> {l.label}
          </button>
        ))}
      </div>
    </div>
  );
}

// ============================================================
// ACTION TRIGGERS SETTINGS
// ============================================================
const SENTIMENT_OPTS = [
  { value: '', label: 'Any sentiment' },
  { value: 'negative', label: '😠 Negative' },
  { value: 'neutral', label: '😐 Neutral' },
  { value: 'positive', label: '😊 Positive' },
];

const ACTION_TYPES = [
  { value: 'in_app_alert', label: '🔔 In-app alert' },
  { value: 'email', label: '📧 Email (coming soon)', disabled: true },
  { value: 'slack', label: '💬 Slack (coming soon)', disabled: true },
  { value: 'webhook', label: '🔗 Webhook (coming soon)', disabled: true },
];

function ActionTriggersSettings({ biz, org }: { biz: any; org: any }) {
  const supabase = createClient();
  const [triggers, setTriggers] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);

  // Form
  const [editId, setEditId] = useState<string | null>(null);
  const [name, setName] = useState('');
  const [topics, setTopics] = useState('');
  const [phrases, setPhrases] = useState('');
  const [minRating, setMinRating] = useState<number | ''>('');
  const [sentimentFilter, setSentimentFilter] = useState('');
  const [actionType, setActionType] = useState('in_app_alert');

  // Test
  const [testText, setTestText] = useState('');
  const [testResults, setTestResults] = useState<any[] | null>(null);
  const [testing, setTesting] = useState(false);

  const loadTriggers = async () => {
    const res = await fetch(`/api/triggers?biz_id=${biz.id}`);
    const data = await res.json();
    setTriggers(data.triggers || []);
    setLoading(false);
  };

  useEffect(() => { loadTriggers(); }, [biz.id]);

  const resetForm = () => {
    setEditId(null); setName(''); setTopics(''); setPhrases('');
    setMinRating(''); setSentimentFilter(''); setActionType('in_app_alert');
  };

  const handleSave = async () => {
    if (!name.trim()) return;
    setSaving(true);
    const payload = {
      org_id: org.id, biz_id: biz.id, name: name.trim(),
      match_topics: topics.split(',').map(s => s.trim()).filter(Boolean),
      match_phrases: phrases.split(',').map(s => s.trim()).filter(Boolean),
      min_rating: minRating === '' ? null : Number(minRating),
      sentiment_filter: sentimentFilter || null,
      action_type: actionType,
    };
    await fetch('/api/triggers', {
      method: editId ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(editId ? { id: editId, ...payload } : payload),
    });
    await loadTriggers();
    resetForm();
    setSaving(false);
  };

  const handleEdit = (trig: any) => {
    setEditId(trig.id); setName(trig.name);
    setTopics((trig.match_topics || []).join(', '));
    setPhrases((trig.match_phrases || []).join(', '));
    setMinRating(trig.min_rating ?? '');
    setSentimentFilter(trig.sentiment_filter || '');
    setActionType(trig.action_type || 'in_app_alert');
  };

  const handleDelete = async (id: string) => {
    if (!confirm('Delete this trigger?')) return;
    await fetch(`/api/triggers?id=${id}`, { method: 'DELETE' });
    await loadTriggers();
  };

  const handleToggle = async (id: string, current: boolean) => {
    await fetch('/api/triggers', {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, is_enabled: !current }),
    });
    await loadTriggers();
  };

  const handleTest = async () => {
    if (!testText.trim()) return;
    setTesting(true);
    const res = await fetch('/api/triggers/test', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ biz_id: biz.id, test_text: testText }),
    });
    const data = await res.json();
    setTestResults(data.matches || []);
    setTesting(false);
  };

  if (loading) return <div className="text-center py-8 text-surface-400">Loading triggers...</div>;

  return (
    <div className="space-y-6 max-w-2xl">
      {/* Create/Edit */}
      <div className="bg-white rounded-2xl border border-surface-100 p-6 space-y-4">
        <h3 className="font-semibold text-surface-800">{editId ? '✏️ Edit Trigger' : '⚡ New Action Trigger'}</h3>
        <Input label="Name" value={name} onChange={e => setName(e.target.value)} placeholder="e.g., Negative parking reviews" />
        <Input label="Match topics (comma sep)" value={topics} onChange={e => setTopics(e.target.value)} placeholder="parking, noise, cleanliness" />
        <Input label="Match phrases (comma sep)" value={phrases} onChange={e => setPhrases(e.target.value)} placeholder="too expensive, bad service" />
        <div className="grid grid-cols-2 gap-4">
          <div>
            <label className="text-sm font-medium text-surface-700 block mb-1">Sentiment</label>
            <select value={sentimentFilter} onChange={e => setSentimentFilter(e.target.value)}
              className="w-full rounded-xl border border-surface-200 px-3 py-2.5 text-sm">
              {SENTIMENT_OPTS.map(o => <option key={o.value} value={o.value}>{o.label}</option>)}
            </select>
          </div>
          <div>
            <label className="text-sm font-medium text-surface-700 block mb-1">Min rating</label>
            <select value={minRating} onChange={e => setMinRating(e.target.value === '' ? '' : Number(e.target.value))}
              className="w-full rounded-xl border border-surface-200 px-3 py-2.5 text-sm">
              <option value="">Any</option>
              {[1,2,3,4,5].map(n => <option key={n} value={n}>{n}+</option>)}
            </select>
          </div>
        </div>
        <div>
          <label className="text-sm font-medium text-surface-700 block mb-1">Action</label>
          <div className="flex gap-2 flex-wrap">
            {ACTION_TYPES.map(a => (
              <button key={a.value} onClick={() => !a.disabled && setActionType(a.value)} disabled={a.disabled}
                className={cn('px-3 py-2 rounded-xl border text-sm transition-all',
                  actionType === a.value ? 'border-brand-400 bg-brand-50 text-brand-700' : 'border-surface-200 text-surface-600',
                  a.disabled && 'opacity-40 cursor-not-allowed')}>
                {a.label}
              </button>
            ))}
          </div>
        </div>
        <div className="flex items-center gap-3 pt-2">
          <Button onClick={handleSave} loading={saving}>{editId ? 'Update' : 'Create trigger'}</Button>
          {editId && <button onClick={resetForm} className="text-sm text-surface-500 hover:text-surface-700">Cancel</button>}
        </div>
      </div>

      {/* List */}
      {triggers.length > 0 && (
        <div className="bg-white rounded-2xl border border-surface-100 p-6">
          <h3 className="font-semibold text-surface-800 mb-4">Active Triggers ({triggers.length})</h3>
          <div className="space-y-3">
            {triggers.map(trig => (
              <div key={trig.id} className={cn('rounded-xl border p-4 transition-all',
                trig.is_enabled ? 'border-surface-200 bg-white' : 'border-surface-100 bg-surface-50 opacity-60')}>
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-3">
                    <button onClick={() => handleToggle(trig.id, trig.is_enabled)}
                      className={cn('relative w-10 h-5 rounded-full transition-colors', trig.is_enabled ? 'bg-brand-500' : 'bg-surface-300')}>
                      <span className={cn('absolute top-0.5 w-4 h-4 rounded-full bg-white shadow transition-transform', trig.is_enabled ? 'translate-x-5' : 'translate-x-0.5')} />
                    </button>
                    <span className="font-medium text-surface-800 text-sm">{trig.name}</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <button onClick={() => handleEdit(trig)} className="text-xs text-brand-600 hover:text-brand-700">Edit</button>
                    <button onClick={() => handleDelete(trig.id)} className="text-xs text-red-500 hover:text-red-700">Delete</button>
                  </div>
                </div>
                <div className="mt-2 flex flex-wrap gap-1.5">
                  {trig.match_topics?.map((t: string) => <span key={t} className="px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 text-[10px] font-medium">topic: {t}</span>)}
                  {trig.match_phrases?.map((p: string) => <span key={p} className="px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 text-[10px] font-medium">phrase: {p}</span>)}
                  {trig.sentiment_filter && <span className="px-2 py-0.5 rounded-full bg-purple-50 text-purple-700 text-[10px] font-medium">{trig.sentiment_filter}</span>}
                  <span className="px-2 py-0.5 rounded-full bg-surface-100 text-surface-600 text-[10px]">{trig.action_type}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Test */}
      <div className="bg-white rounded-2xl border border-surface-100 p-6 space-y-4">
        <h3 className="font-semibold text-surface-800">🧪 Test Triggers</h3>
        <p className="text-xs text-surface-500">Paste a review to see which triggers would fire.</p>
        <textarea value={testText} onChange={e => setTestText(e.target.value)} rows={3}
          placeholder="E.g.: The parking was terrible and staff was rude..."
          className="w-full rounded-xl border border-surface-200 px-4 py-3 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 transition-all" />
        <Button onClick={handleTest} loading={testing} variant="secondary">Run match</Button>
        {testResults !== null && (
          <div className="mt-3">
            {testResults.length === 0 ? (
              <p className="text-sm text-surface-400">No triggers matched.</p>
            ) : testResults.map((m: any) => (
              <div key={m.id} className="flex items-center gap-2 text-sm">
                <span className="text-emerald-500">⚡</span>
                <span className="font-medium">{m.name}</span>
                <span className="text-xs text-surface-400">matched {m.match_reason}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

// ============================================================
// TEAM SETTINGS — member list, invite, role change, remove
// ============================================================
const ROLE_LABELS: Record<string, { label: string; color: string }> = {
  owner: { label: 'Owner', color: 'bg-amber-100 text-amber-800' },
  manager: { label: 'Manager', color: 'bg-blue-100 text-blue-800' },
  staff: { label: 'Staff', color: 'bg-surface-100 text-surface-600' },
};

interface TeamMember {
  id: string;
  user_id: string;
  org_id: string;
  role: string;
  invited_email: string | null;
  accepted_at: string | null;
  created_at: string;
  full_name: string | null;
  avatar_url: string | null;
}

function TeamSettings({ org }: { org: any }) {
  const { membership } = useWorkspace();
  const [members, setMembers] = useState<TeamMember[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  // Invite form
  const [inviteEmail, setInviteEmail] = useState('');
  const [inviteRole, setInviteRole] = useState('staff');
  const [inviting, setInviting] = useState(false);
  const [inviteMsg, setInviteMsg] = useState<string | null>(null);

  // Role edit
  const [editingId, setEditingId] = useState<string | null>(null);
  const [editRole, setEditRole] = useState('staff');

  const isOwner = membership?.role === 'owner';
  const isManagerOrOwner = membership?.role === 'owner' || membership?.role === 'manager';

  const loadMembers = async () => {
    setLoading(true);
    setError(null);
    try {
      const res = await fetch(`/api/team?org_id=${org.id}`);
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      setMembers(data.members || []);
    } catch (e: any) {
      setError(e.message);
    }
    setLoading(false);
  };

  useEffect(() => { loadMembers(); }, [org.id]);

  const handleInvite = async () => {
    if (!inviteEmail.trim()) return;
    setInviting(true);
    setInviteMsg(null);
    try {
      const res = await fetch('/api/team/invite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ org_id: org.id, email: inviteEmail.trim(), role: inviteRole }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || data.error);
      setInviteEmail('');
      setInviteMsg('✅ Invite sent');
      await loadMembers();
    } catch (e: any) {
      setInviteMsg('❌ ' + e.message);
    }
    setInviting(false);
  };

  const handleRoleChange = async (membershipId: string, newRole: string) => {
    try {
      const res = await fetch('/api/team/role', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ membership_id: membershipId, role: newRole }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || data.error);
      setEditingId(null);
      await loadMembers();
    } catch (e: any) {
      alert(e.message);
    }
  };

  const handleRemove = async (membershipId: string, name: string) => {
    if (!confirm(`Remove ${name || 'this member'} from the team?`)) return;
    try {
      const res = await fetch(`/api/team/member?id=${membershipId}`, { method: 'DELETE' });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || data.error);
      await loadMembers();
    } catch (e: any) {
      alert(e.message);
    }
  };

  if (loading) return <div className="text-center py-8 text-surface-400">Loading team...</div>;
  if (error) return <div className="text-center py-8 text-red-500">Error: {error}</div>;

  const accepted = members.filter(m => m.accepted_at);
  const pending = members.filter(m => !m.accepted_at);

  return (
    <div className="space-y-6 max-w-2xl">
      {/* Member list */}
      <div className="bg-white rounded-2xl border border-surface-100 p-6">
        <h3 className="font-semibold text-surface-800 mb-4">Team Members ({accepted.length})</h3>
        <div className="space-y-3">
          {accepted.map(m => {
            const isSelf = m.user_id === membership?.user_id;
            const rl = ROLE_LABELS[m.role] || ROLE_LABELS.staff;
            return (
              <div key={m.id} className="flex items-center gap-3 py-2 px-3 rounded-xl hover:bg-surface-50 transition-colors">
                {/* Avatar */}
                <div className="w-8 h-8 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xs font-bold shrink-0">
                  {m.full_name?.charAt(0)?.toUpperCase() || m.invited_email?.charAt(0)?.toUpperCase() || '?'}
                </div>

                {/* Name + email */}
                <div className="flex-1 min-w-0">
                  <p className="text-sm font-medium text-surface-800 truncate">
                    {m.full_name || m.invited_email || 'Unknown'}
                    {isSelf && <span className="text-xs text-surface-400 ml-1">(you)</span>}
                  </p>
                  {m.invited_email && m.full_name && (
                    <p className="text-xs text-surface-400 truncate">{m.invited_email}</p>
                  )}
                </div>

                {/* Role badge / editor */}
                {editingId === m.id ? (
                  <div className="flex items-center gap-2">
                    <select value={editRole} onChange={e => setEditRole(e.target.value)}
                      className="rounded-lg border border-surface-200 px-2 py-1 text-xs">
                      <option value="staff">Staff</option>
                      <option value="manager">Manager</option>
                      <option value="owner">Owner</option>
                    </select>
                    <button onClick={() => handleRoleChange(m.id, editRole)}
                      className="text-xs text-brand-600 hover:text-brand-700 font-medium">Save</button>
                    <button onClick={() => setEditingId(null)}
                      className="text-xs text-surface-400 hover:text-surface-600">Cancel</button>
                  </div>
                ) : (
                  <div className="flex items-center gap-2">
                    <span className={cn('px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase', rl.color)}>
                      {rl.label}
                    </span>
                    {isOwner && !isSelf && (
                      <>
                        <button onClick={() => { setEditingId(m.id); setEditRole(m.role); }}
                          className="text-xs text-brand-600 hover:text-brand-700">Role</button>
                        <button onClick={() => handleRemove(m.id, m.full_name || m.invited_email || '')}
                          className="text-xs text-red-500 hover:text-red-700">Remove</button>
                      </>
                    )}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>

      {/* Pending invites */}
      {pending.length > 0 && (
        <div className="bg-white rounded-2xl border border-surface-100 p-6">
          <h3 className="font-semibold text-surface-800 mb-4">Pending Invites ({pending.length})</h3>
          <div className="space-y-2">
            {pending.map(m => (
              <div key={m.id} className="flex items-center gap-3 py-2 px-3 rounded-xl bg-amber-50/50">
                <div className="w-8 h-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center text-xs font-bold shrink-0">
                  ✉
                </div>
                <div className="flex-1 min-w-0">
                  <p className="text-sm font-medium text-surface-700 truncate">{m.invited_email}</p>
                  <p className="text-xs text-surface-400">Invited {new Date(m.created_at).toLocaleDateString()}</p>
                </div>
                <span className={cn('px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase', ROLE_LABELS[m.role]?.color)}>
                  {ROLE_LABELS[m.role]?.label || m.role}
                </span>
                {isManagerOrOwner && (
                  <button onClick={() => handleRemove(m.id, m.invited_email || '')}
                    className="text-xs text-red-500 hover:text-red-700">Cancel</button>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Invite form */}
      {isManagerOrOwner && (
        <div className="bg-white rounded-2xl border border-surface-100 p-6 space-y-4">
          <h3 className="font-semibold text-surface-800">Invite Member</h3>
          <div className="flex gap-3">
            <Input
              label="Email"
              type="email"
              value={inviteEmail}
              onChange={e => setInviteEmail(e.target.value)}
              placeholder="colleague@hotel.com"
              className="flex-1"
            />
            <div>
              <label className="text-sm font-medium text-surface-700 block mb-1">Role</label>
              <select value={inviteRole} onChange={e => setInviteRole(e.target.value)}
                className="rounded-xl border border-surface-200 px-3 py-2.5 text-sm">
                <option value="staff">Staff</option>
                <option value="manager">Manager</option>
              </select>
            </div>
          </div>
          <div className="flex items-center gap-3">
            <Button onClick={handleInvite} loading={inviting}>Send Invite</Button>
            {inviteMsg && <span className="text-sm">{inviteMsg}</span>}
          </div>
          <p className="text-xs text-surface-400">
            Invited users will join this organization when they sign up or log in with this email.
          </p>
        </div>
      )}

      {/* Permissions info */}
      <div className="bg-surface-50 rounded-xl p-4 border border-surface-100">
        <p className="text-xs text-surface-500">
          <strong>Permissions:</strong> Owners can manage all settings, change roles, and remove members.
          Managers can invite members and manage business settings. Staff can view and generate responses.
        </p>
      </div>
    </div>
  );
}
