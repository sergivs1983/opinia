'use client';

import { useState } from 'react';
import { useRouter } from 'next/navigation';
import Logo from '@/components/ui/Logo';
import Button from '@/components/ui/Button';
import StarRating from '@/components/ui/StarRating';
import ResponseCard from '@/components/ui/ResponseCard';
import { createClient } from '@/lib/supabase/client';

const DEMO_RESPONSES = {
  review: "Bona ubicació i l'habitació neta, però a la nit es sentia molt soroll del carrer i no vam poder descansar bé. El personal amable.",
  rating: 4,
  option_a: "Moltes gràcies pel teu comentari! Ens alegra molt que hagis gaudit de la ubicació i la neteja de l'habitació, i que el nostre equip t'hagi tractat bé. Lamentem molt el tema del soroll nocturn — és un punt que estem treballant activament amb millores d'aïllament. La propera vegada, no dubtis a demanar una habitació interior, que són molt més tranquil·les. T'esperem de nou!",
  option_b: "Agraïm la seva valoració de 4 estrelles. Prenem nota del seu comentari sobre el soroll nocturn i l'informem que estem implementant mesures d'aïllament acústic per millorar el descans dels nostres hostes. Disposem d'habitacions interiors que ofereixen un ambient més tranquil. El nostre equip queda a la seva disposició per a qualsevol consulta futura. Gràcies per la seva confiança.",
  option_c: "Quin plaer rebre les seves paraules. Celebrem que la ubicació i l'atenció del nostre equip hagin estat a l'altura. Som ben conscients que el descans és sagrat, i precisament per això estem invertint en millorar l'experiència nocturna dels nostres hostes. Permeti'ns l'oportunitat de sorprendre'l amb una de les nostres habitacions interiors, un autèntic refugi de tranquil·litat. Serà un honor tornar-lo a acollir.",
};

export default function LandingPage() {
  const [url, setUrl] = useState('');
  const [loading, setLoading] = useState(false);
  const router = useRouter();
  const supabase = createClient();

  const handleAutoConfigure = async () => {
    if (!url.trim()) return;
    // Store URL in sessionStorage for onboarding
    sessionStorage.setItem('opinia_url', url);
    router.push('/onboarding');
  };

  const handleGoogleLogin = async () => {
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: `${window.location.origin}/callback` },
    });
    if (error) console.error('Login error:', error);
  };

  const handleTryDemo = () => {
    sessionStorage.setItem('opinia_demo', 'true');
    router.push('/dashboard');
  };

  return (
    <div className="min-h-screen relative overflow-hidden">
      {/* Background */}
      <div className="fixed inset-0 bg-gradient-to-br from-slate-50 via-white to-brand-50/30 -z-10" />
      <div className="fixed top-0 right-0 w-[800px] h-[800px] bg-gradient-to-bl from-brand-100/40 via-violet-100/20 to-transparent rounded-full blur-3xl -z-10 translate-x-1/3 -translate-y-1/3" />
      <div className="fixed bottom-0 left-0 w-[600px] h-[600px] bg-gradient-to-tr from-amber-100/30 via-brand-100/20 to-transparent rounded-full blur-3xl -z-10 -translate-x-1/4 translate-y-1/4" />

      {/* Navbar */}
      <nav className="sticky top-0 z-50 backdrop-blur-lg bg-white/70 border-b border-surface-100">
        <div className="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
          <Logo size="md" />
          <div className="flex items-center gap-3">
            <Button variant="ghost" size="sm" onClick={handleTryDemo}>
              Provar demo
            </Button>
            <Button variant="primary" size="sm" onClick={handleGoogleLogin}>
              Entrar amb Google
            </Button>
          </div>
        </div>
      </nav>

      {/* Hero */}
      <main className="max-w-6xl mx-auto px-6">
        <section className="pt-20 pb-16 md:pt-28 md:pb-24">
          <div className="max-w-3xl mx-auto text-center">
            {/* Animated hero logo */}
            <div className="flex justify-center mb-8 animate-fade-in">
              <div className="relative">
                {/* Glow behind logo */}
                <div className="absolute inset-0 bg-gradient-to-r from-brand-400/20 via-violet-400/20 to-brand-400/20 rounded-full blur-2xl scale-150 animate-pulse" />
                <Logo size="hero" animate />
              </div>
            </div>

            <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-50 border border-brand-100 text-brand-700 text-sm font-medium mb-6 animate-fade-in" style={{ animationDelay: '200ms' }}>
              <span className="w-2 h-2 rounded-full bg-brand-500 animate-pulse" />
              Respostes professionals en 30 segons
            </div>

            <h1 className="font-display text-4xl md:text-6xl font-bold tracking-tight text-surface-900 leading-[1.1] mb-6 animate-slide-up">
              Respon a cada ressenya
              <br />
              <span className="gradient-text">com un professional</span>
            </h1>

            <p className="text-lg md:text-xl text-surface-500 max-w-2xl mx-auto mb-10 leading-relaxed animate-slide-up" style={{ animationDelay: '100ms' }}>
              Genera respostes personalitzades amb IA per a restaurants, hotels i apartaments.
              Configura el perfil de marca en un clic.
            </p>

            {/* Main CTA */}
            <div className="max-w-xl mx-auto animate-slide-up" style={{ animationDelay: '200ms' }}>
              <div className="glass-card rounded-2xl p-2 shadow-xl border border-surface-200/50">
                <div className="flex gap-2">
                  <input
                    type="url"
                    value={url}
                    onChange={(e) => setUrl(e.target.value)}
                    placeholder="Enganxa la web del teu negoci o perfil de Google/TripAdvisor"
                    className="flex-1 px-5 py-3.5 rounded-xl bg-white border border-surface-100 text-surface-900 placeholder:text-surface-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 text-sm"
                    onKeyDown={(e) => e.key === 'Enter' && handleAutoConfigure()}
                  />
                  <Button
                    size="lg"
                    onClick={handleAutoConfigure}
                    loading={loading}
                    className="whitespace-nowrap"
                  >
                    ✨ Auto-configurar
                  </Button>
                </div>
              </div>
              <p className="text-xs text-surface-400 mt-3">
                30 segons · sense targeta · 1 prova gratuïta sense registre
              </p>
            </div>

            {/* Auth options */}
            <div className="flex items-center justify-center gap-3 mt-8 animate-slide-up" style={{ animationDelay: '300ms' }}>
              <Button variant="secondary" onClick={handleGoogleLogin} className="gap-2">
                <svg className="w-4 h-4" viewBox="0 0 24 24">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Google
              </Button>
              <Button variant="secondary" onClick={() => router.push('/login')} className="gap-2">
                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
                Correu
              </Button>
            </div>
          </div>
        </section>

        {/* How it works */}
        <section className="py-16 border-t border-surface-100">
          <h2 className="font-display text-2xl md:text-3xl font-bold text-center mb-12">
            Com funciona?
          </h2>
          <div className="grid md:grid-cols-3 gap-8">
            {[
              { step: '1', icon: '🔗', title: 'Configura el teu perfil', desc: 'Enganxa la URL del teu negoci i la IA auto-detecta nom, tipus i to.' },
              { step: '2', icon: '📝', title: 'Enganxa la ressenya', desc: 'Copia la ressenya del client, selecciona el rating i el sentiment es calcula sol.' },
              { step: '3', icon: '✨', title: 'Escull la resposta', desc: 'Tria entre 3 tons: Proper, Professional o Premium. Copia i publica!' },
            ].map((item) => (
              <div key={item.step} className="relative group">
                <div className="glass-card rounded-2xl p-6 h-full border border-surface-100 hover:border-brand-200 transition-all hover:shadow-lg">
                  <div className="flex items-center gap-3 mb-4">
                    <span className="flex items-center justify-center w-8 h-8 rounded-full bg-brand-100 text-brand-700 font-bold text-sm">
                      {item.step}
                    </span>
                    <span className="text-2xl">{item.icon}</span>
                  </div>
                  <h3 className="font-display font-semibold text-lg mb-2">{item.title}</h3>
                  <p className="text-surface-500 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        {/* Demo examples */}
        <section className="py-16 border-t border-surface-100" id="exemples">
          <div className="text-center mb-12">
            <h2 className="font-display text-2xl md:text-3xl font-bold mb-3">
              Exemples de respostes
            </h2>
            <p className="text-surface-500 max-w-xl mx-auto">
              Basats en una ressenya real de 4★ sobre soroll nocturn
            </p>
          </div>

          {/* Demo review */}
          <div className="max-w-2xl mx-auto mb-8">
            <div className="glass-card rounded-2xl p-5 border border-surface-200/50">
              <div className="flex items-center gap-3 mb-3">
                <div className="w-10 h-10 rounded-full bg-surface-200 flex items-center justify-center text-surface-500 font-semibold text-sm">
                  JM
                </div>
                <div>
                  <p className="font-medium text-sm">Joan M.</p>
                  <div className="flex items-center gap-1">
                    <StarRating rating={DEMO_RESPONSES.rating} readonly size="sm" />
                    <span className="text-xs text-surface-400 ml-1">fa 2 dies</span>
                  </div>
                </div>
              </div>
              <p className="text-sm text-surface-700 leading-relaxed italic">
                &quot;{DEMO_RESPONSES.review}&quot;
              </p>
            </div>
          </div>

          {/* Demo response cards */}
          <div className="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
            <ResponseCard tone="proper" content={DEMO_RESPONSES.option_a} />
            <ResponseCard tone="professional" content={DEMO_RESPONSES.option_b} />
            <ResponseCard tone="premium" content={DEMO_RESPONSES.option_c} />
          </div>
        </section>

        {/* Final CTA */}
        <section className="py-20 text-center">
          <div className="glass-card rounded-3xl p-10 md:p-16 border border-brand-100 bg-gradient-to-br from-brand-50/50 to-violet-50/30 max-w-3xl mx-auto">
            <h2 className="font-display text-2xl md:text-3xl font-bold mb-4">
              Comença a respondre professionalment
            </h2>
            <p className="text-surface-500 mb-8 max-w-lg mx-auto">
              Configura el teu negoci en 30 segons i genera respostes que reforcen la teva marca.
            </p>
            <div className="flex flex-col sm:flex-row items-center justify-center gap-3">
              <Button size="lg" onClick={handleTryDemo}>
                ✨ Provar ara gratis
              </Button>
              <Button variant="secondary" size="lg" onClick={handleGoogleLogin}>
                Crear compte
              </Button>
            </div>
          </div>
        </section>
      </main>

      {/* Footer */}
      <footer className="border-t border-surface-100 py-8">
        <div className="max-w-6xl mx-auto px-6 flex items-center justify-between">
          <Logo size="sm" />
          <p className="text-xs text-surface-400">
            © 2026 OpinIA. Fet amb IA per a la hostaleria.
          </p>
        </div>
      </footer>
    </div>
  );
}
