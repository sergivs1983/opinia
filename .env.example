# ═══════════════════════════════════════════════════════════════════════════════
# OpinIA — Environment Variables example
# Copy to .env.local for local dev; set on Vercel/CI as environment variables.
# NEVER commit .env.local or any file containing real secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# ── LLM Provider (at least one REQUIRED) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (optional — needed for paid plans) ─────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...

# ── Cron Jobs (REQUIRED if using /api/jobs) ───────────────────────────────────
CRON_SECRET=generate-a-random-string-here

# ── OAuth Token Encryption (REQUIRED) ────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_KEY_V1=<64-hex-chars>

# Token migration phase
TOKEN_MIGRATION_PHASE=dual_write

# ── CSRF Allowlist (REQUIRED for API security gate) ──────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Upstash Redis — Rate Limiting + AI Quota (Bloc 8) ────────────────────────
# Required for persistent rate limits in production.
# Without these, an in-process ephemeral store is used (dev/test only).
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── AI Daily Quota per business (Bloc 8) ─────────────────────────────────────
# Max LLM calls per business per calendar day (UTC), by plan.
AI_DAILY_QUOTA_CALLS_FREE=50
AI_DAILY_QUOTA_CALLS_PRO=1000
AI_DAILY_QUOTA_CALLS_ENTERPRISE=10000

# ── Sentry — Error Monitoring (Bloc 9) ───────────────────────────────────────
# Get from: Sentry project → Settings → Client Keys (DSN)
# Set in Vercel: Project Settings → Environment Variables → SENTRY_DSN
# Leave empty locally to disable Sentry (events are dropped silently).
SENTRY_DSN=
# Optional: suppress Sentry telemetry & auto-source-map upload in CI
SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_WARNING=true
