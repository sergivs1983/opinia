# ═══════════════════════════════════════════════════════════════════════════════
# OpinIA — Environment Variables example
# Copy to .env.local for local dev; set on Vercel/CI as environment variables.
# NEVER commit .env.local or any file containing real secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# ── LLM Provider (at least one REQUIRED) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (optional — needed for paid plans) ─────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...

# ── Cron Jobs (REQUIRED if using /api/jobs) ───────────────────────────────────
CRON_SECRET=generate-a-random-string-here

# ── OAuth Token Encryption (REQUIRED) ────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_KEY_V1=<64-hex-chars>

# Token migration phase
TOKEN_MIGRATION_PHASE=dual_write

# ── CSRF Allowlist (REQUIRED for API security gate) ──────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
