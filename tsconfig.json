{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "next-intl": ["./src/lib/next-intl/compat/index.tsx"],
      "next-intl/server": ["./src/lib/next-intl/compat/server.ts"],
      "next-intl/middleware": ["./src/lib/next-intl/compat/middleware.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "src/__tests__",
    "tests",
    ".e2e",
    "playwright-report",
    "test-results"
  ]
}
