# ═══════════════════════════════════════════
# OpinIA — Environment Variables
# Copy to .env.local for local dev.
# On Vercel: Settings → Environment Variables.
# ═══════════════════════════════════════════

# ── Supabase (REQUIRED) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── LLM Provider (at least one REQUIRED) ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (optional — needed for paid plans) ──
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...

# ── Cron Jobs (REQUIRED if using /api/jobs) ──
CRON_SECRET=generate-a-random-string-here

# ── OAuth Token Encryption (REQUIRED for Gate 1.4) ──────────────────────────
# AES-256-GCM key for encrypting OAuth tokens in integrations_secrets.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Format: hex (64 chars) or base64 (44 chars) — must decode to exactly 32 bytes.
# NEVER use NEXT_PUBLIC_ prefix. NEVER commit real keys.
OAUTH_ENCRYPTION_KEY_V1=<generate-64-hex-chars>

# Token migration phase: "dual_write" (default) | "new_only"
#   dual_write: write to integrations_secrets (encrypted) AND legacy columns (compat)
#   new_only:   write to integrations_secrets only; clears legacy columns on write
# Switch to new_only ONLY after backfill is complete and verified.
TOKEN_MIGRATION_PHASE=dual_write

# ── App Config (optional) ──
# NEXT_PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_APP_VERSION=1.0.0
